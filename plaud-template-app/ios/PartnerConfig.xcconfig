// ============================================================
// Plaud SDK Configuration
//
// Create "PartnerConfig.local.xcconfig" (git-ignored) with your
// real credentials. It will override the placeholders below.
//
// Or edit the values below directly (not recommended for git).
// ============================================================

// Backend host that mints per-user access tokens (POST /api/user-token).
// Bare host only — NO scheme. xcconfig treats "//" as a comment, so a value
// like "https://host" gets truncated to "https:". The app prepends https://
// and appends /api/user-token at runtime. e.g. your-backend.vercel.app
USER_TOKEN_BACKEND_URL = YOUR_BACKEND_HERE

// [Optional fallback] Hardcoded User Access Token. Only used if the backend
// fetch above is not configured. Leave as-is when using USER_TOKEN_BACKEND_URL.
USER_ACCESS_TOKEN = YOUR_USER_ACCESS_TOKEN_HERE

// Client ID & API Key (required for transcription API)
PLAUD_CLIENT_ID = YOUR_CLIENT_ID_HERE
PLAUD_API_KEY = YOUR_API_KEY_HERE

// [Optional] "Sync when idle" destination — where the DEVICE uploads recordings
// on its own over WiFi (the phone is not involved). When unset, the device keeps
// its factory-default endpoint. Bare host only — NO scheme; xcconfig treats "//"
// as a comment, so the app prepends "wss://". e.g. your-backend.example.com/ingest
IDLE_SYNC_WEBSOCKET_HOST = YOUR_IDLE_SYNC_HOST_HERE
IDLE_SYNC_SERVER_TOKEN = YOUR_IDLE_SYNC_SERVER_TOKEN_HERE
IDLE_SYNC_DEVICE_TOKEN = YOUR_IDLE_SYNC_DEVICE_TOKEN_HERE

// [Deprecated] Backward compatibility alias
PARTNER_TOKEN = $(USER_ACCESS_TOKEN)

// Import local overrides (must be LAST to take precedence)
#include? "PartnerConfig.local.xcconfig"
